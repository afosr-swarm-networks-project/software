#!/usr/bin/env python3
import rclpy
from rf_pipeline.scoreboard import ScoreboardNode
import sys

if __name__ == "__main__":
    rclpy.init(args=sys.argv[1:])
    node = ScoreboardNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
